{
  "name": "nexera",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready full-stack digital agency website for NexEra.",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "typecheck": "npm --workspaces run typecheck",
    "seed": "npm --workspace apps/api run seed"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
